  - character: {fileID: 11400000, guid: fbe0e12a368207d42aadf48040e4ab93, type: 2}
    text: "No, thank you, I\u2019ll be fine on my own"
    expression: {fileID: 0}
  - character: {fileID: 11400000, guid: ceb1a7909d01705478cf655dbaaaee6e, type: 2}
    text: " Okay, then that\u2019s fine!"
    expression: {fileID: 0}
  - character: {fileID: 11400000, guid: ceb1a7909d01705478cf655dbaaaee6e, type: 2}
    text: 'Have a good night, miss. '
    expression: {fileID: 0}
  - character: {fileID: 11400000, guid: fbe0e12a368207d42aadf48040e4ab93, type: 2}
    text: Thank you.
    expression: {fileID: 0}
  - character: {fileID: 11400000, guid: fbe0e12a368207d42aadf48040e4ab93, type: 2}
