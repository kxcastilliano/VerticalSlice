  lines:
  - character: {fileID: 11400000, guid: fbe0e12a368207d42aadf48040e4ab93, type: 2}
    text: "( Though this man seems polite, I should probably start making my way
      to the cashier\u2019s cage\u2026.)"
    expression: {fileID: 0}
  - character: {fileID: 11400000, guid: ceb1a7909d01705478cf655dbaaaee6e, type: 2}
    text: Oh? Do you have somewhere to be?
    expression: {fileID: 0}
  - character: {fileID: 11400000, guid: fbe0e12a368207d42aadf48040e4ab93, type: 2}
    text: Oh, yes! I plan to get these chips redeemed and head on out.
    expression: {fileID: 0}
  - character: {fileID: 11400000, guid: fbe0e12a368207d42aadf48040e4ab93, type: 2}
    text: It is getting late
    expression: {fileID: 0}
  - character: {fileID: 11400000, guid: ceb1a7909d01705478cf655dbaaaee6e, type: 2}
    text: Ohh, I see.
    expression: {fileID: 0}
  - character: {fileID: 11400000, guid: ceb1a7909d01705478cf655dbaaaee6e, type: 2}
    text: 'Do you mind if I tag along?

'
    expression: {fileID: 0}
