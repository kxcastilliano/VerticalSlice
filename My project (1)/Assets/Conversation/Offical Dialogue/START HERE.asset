  speakerLeft: {fileID: 11400000, guid: ceb1a7909d01705478cf655dbaaaee6e, type: 2}
  speakerRight: {fileID: 11400000, guid: fbe0e12a368207d42aadf48040e4ab93, type: 2}
  lines:
  - character: {fileID: 11400000, guid: fbe0e12a368207d42aadf48040e4ab93, type: 2}
    text: "There\u2019s actually no way this is real\u2026"
    expression: {fileID: 21300000, guid: e58fb351279cd7949a16b4b127917c48, type: 3}
  - character: {fileID: 11400000, guid: fbe0e12a368207d42aadf48040e4ab93, type: 2}
    text: What am I even going to do with this many chips?
    expression: {fileID: 21300000, guid: e58fb351279cd7949a16b4b127917c48, type: 3}
  - character: {fileID: 11400000, guid: fbe0e12a368207d42aadf48040e4ab93, type: 2}
    text: "I guess I can save that question for after I redeem them\u2026"
    expression: {fileID: 21300000, guid: e58fb351279cd7949a16b4b127917c48, type: 3}
  - character: {fileID: 11400000, guid: fbe0e12a368207d42aadf48040e4ab93, type: 2}
    text: ( I opt out of another round and place the chips in my purse)
    expression: {fileID: 21300000, guid: e58fb351279cd7949a16b4b127917c48, type: 3}
  - character: {fileID: 11400000, guid: fbe0e12a368207d42aadf48040e4ab93, type: 2}
    text: "(Before I go over to exchange my chips\u2026 I could\u2019ve sworn that
      I felt some wandering eyes on me while playing.)\r\n"
    expression: {fileID: 21300000, guid: 438a71dfbf50c4b41aff343e3431c1e9, type: 3}
  - character: {fileID: 11400000, guid: fbe0e12a368207d42aadf48040e4ab93, type: 2}
    text: "(I turn around and see a man staring from the casino\u2019s bar)"
    expression: {fileID: 21300000, guid: 438a71dfbf50c4b41aff343e3431c1e9, type: 3}
